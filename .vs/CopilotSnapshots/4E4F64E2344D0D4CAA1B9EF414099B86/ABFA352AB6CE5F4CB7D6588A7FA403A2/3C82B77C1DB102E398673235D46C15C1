#!/usr/bin/env bash
set -euo pipefail

APP_NAME="usb-logger"
BIN_SRC=""
CONFIG_SRC=""
UNIT_SRC=""

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --bin)
      BIN_SRC="$2"; shift 2;;
    --config)
      CONFIG_SRC="$2"; shift 2;;
    --unit)
      UNIT_SRC="$2"; shift 2;;
    *)
      echo "Unknown argument: $1"; exit 2;;
  esac
done

if [[ -z "${BIN_SRC}" ]]; then
  if [[ -x "${PKG_ROOT}/bin/${APP_NAME}" ]]; then
    BIN_SRC="${PKG_ROOT}/bin/${APP_NAME}"
  elif [[ -x "${PKG_ROOT}/out/build/linux-release/${APP_NAME}" ]]; then
    BIN_SRC="${PKG_ROOT}/out/build/linux-release/${APP_NAME}"
  elif [[ -x "${PKG_ROOT}/out/build/linux-debug/${APP_NAME}" ]]; then
    BIN_SRC="${PKG_ROOT}/out/build/linux-debug/${APP_NAME}"
  elif [[ -x "${PKG_ROOT}/build/${APP_NAME}" ]]; then
    BIN_SRC="${PKG_ROOT}/build/${APP_NAME}"
  else
    echo "Could not find built binary. Pass --bin <path-to-usb-logger>." >&2
    exit 3
  fi
fi

if [[ -z "${CONFIG_SRC}" ]]; then
  if [[ -f "${PKG_ROOT}/config/app.toml" ]]; then
    CONFIG_SRC="${PKG_ROOT}/config/app.toml"
  elif [[ -f "${PKG_ROOT}/config/app.toml" ]]; then
    CONFIG_SRC="${PKG_ROOT}/config/app.toml"
  else
    echo "Could not find config/app.toml. Pass --config <path-to-app.toml>." >&2
    exit 4
  fi
fi

if [[ -z "${UNIT_SRC}" ]]; then
  if [[ -f "${PKG_ROOT}/systemd/${APP_NAME}.service" ]]; then
    UNIT_SRC="${PKG_ROOT}/systemd/${APP_NAME}.service"
  fi
fi

if [[ $EUID -ne 0 ]]; then
  echo "Run as root (sudo)." >&2
  exit 1
fi

install -d -m 0755 /opt/${APP_NAME}
install -m 0755 "${BIN_SRC}" /opt/${APP_NAME}/${APP_NAME}

install -d -m 0755 /etc/${APP_NAME}
if [[ ! -f /etc/${APP_NAME}/app.toml ]]; then
  install -m 0644 "${CONFIG_SRC}" /etc/${APP_NAME}/app.toml
else
  echo "Config already exists at /etc/${APP_NAME}/app.toml (not overwriting)."
fi

install -d -m 0755 /var/log/${APP_NAME}

# Dedicated user (optional but recommended)
if ! id -u ${APP_NAME} >/dev/null 2>&1; then
  useradd --system --no-create-home --shell /usr/sbin/nologin ${APP_NAME}
fi
chown -R ${APP_NAME}:${APP_NAME} /var/log/${APP_NAME}

SERVICE_FILE="/etc/systemd/system/${APP_NAME}.service"
if [[ -n "${UNIT_SRC}" ]]; then
  install -m 0644 "${UNIT_SRC}" "${SERVICE_FILE}"
else
  cat > "${SERVICE_FILE}" <<'EOF'
[Unit]
Description=USB Serial Logger
After=network.target

[Service]
Type=simple
User=usb-logger
Group=usb-logger
ExecStart=/opt/usb-logger/usb-logger /etc/usb-logger/app.toml
Restart=always
RestartSec=2

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/usb-logger
SupplementaryGroups=dialout

[Install]
WantedBy=multi-user.target
EOF
fi

systemctl daemon-reload
systemctl enable ${APP_NAME}.service
systemctl restart ${APP_NAME}.service

systemctl --no-pager --full status ${APP_NAME}.service || true

echo "Installed. Logs in /var/log/${APP_NAME}. Service: systemctl status ${APP_NAME}"
