# usb-logger configuration (TOML)
# Place this file in:
#   ./config/app.toml (dev)
#   /etc/usb-logger/app.toml (prod)

[serial]
port = "/dev/ttyUSB0"
baudrate = 115200
# Supported: "none", "odd", "even"
parity = "none"
# Supported: 5,6,7,8
databits = 8
# Supported: 1,2
stopbits = 1
# Read timeout in milliseconds (keeps CPU low)
read_timeout_ms = 500

[log]
# Directory for log output
directory = "/var/log/usb-logger"
# Base filename (date suffix is appended)
base_name = "usb-logger"
# Reopen log file periodically to handle logrotate/external moves
reopen_interval_s = 5
# Flush each line (safer, a bit slower)
flush_each_line = true

[daemon]
# If the port is missing, wait and retry
retry_port_interval_s = 2
# Backoff after unexpected errors
retry_error_interval_s = 2
# Optional: maximum bytes per line before truncation
max_line_bytes = 4096
